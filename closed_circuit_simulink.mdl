  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">49</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function CL = CirculatingLoad(F_recycle_total, F_fresh_total)

if F_fresh_total &lt;= 0
    CL = 0;
else
    CL = F_recycle_total / F_fresh_total;
end</P>
      </eml>
    </state>
    <data SSID="4" name="F_recycle_total">
      <P Name="scope">INPUT_DATA</P>
